{
  "name": "atlaset-crypto-client",
  "version": "0.1.0",
  "description": "Auditable client-side cryptography helpers for Atlaset.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json --emitDeclarationOnly",
    "prepare": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "libsodium-wrappers-sumo": "0.7.15",
    "shamir-secret-sharing": "0.0.4"
  },
  "devDependencies": {
    "typescript": "~5.9.3",
    "vite": "^7.2.2",
    "vitest": "^4.0.15"
  }
}
